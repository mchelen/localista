# Copy to .env.local and fill in the keys you have. All are optional, and
# in production none are needed: the CI data pipeline (pipeline/, keys as
# Actions secrets) precompiles everything the keyed APIs provide. These
# VITE_* vars only enable the live-API fallback paths, mainly useful in
# local development before pipeline data exists.
#
# NOTE: Vite inlines VITE_* vars into the client bundle — never use keys
# here that you wouldn't publish. CI secrets never reach the bundle.

# State legislators + state bills (incl. DC Council).
# Free key: https://open.pluralpolicy.com/accounts/profile/
VITE_OPENSTATES_API_KEY=

# Federal bills. Free key: https://api.congress.gov/sign-up/
VITE_CONGRESS_GOV_API_KEY=

# Official upcoming-elections list (Civic Information API, Google Cloud Console).
VITE_GOOGLE_CIVIC_API_KEY=

# Only needed at high request volume: https://api.census.gov/data/key_signup.html
VITE_CENSUS_API_KEY=
