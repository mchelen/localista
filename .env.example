# Copy to .env.local and fill in the keys you have. All are optional:
# the app works without any keys (federal reps, jurisdictions, DC local
# data, demographics, computed elections all use keyless open endpoints).
#
# NOTE: Vite inlines VITE_* vars into the client bundle — these keys are
# visible to anyone using the deployed site. Fine for personal use / free
# quotas; put a proxy in front before a public launch (ARCHITECTURE.md §6).

# State legislators + state bills (incl. DC Council).
# Free key: https://open.pluralpolicy.com/accounts/profile/
VITE_OPENSTATES_API_KEY=

# Federal bills. Free key: https://api.congress.gov/sign-up/
VITE_CONGRESS_GOV_API_KEY=

# Official upcoming-elections list (Civic Information API, Google Cloud Console).
VITE_GOOGLE_CIVIC_API_KEY=

# Only needed at high request volume: https://api.census.gov/data/key_signup.html
VITE_CENSUS_API_KEY=
